# Server
PORT=3000
NODE_ENV=development

# MongoDB (bắt buộc)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=quizgenerator
# MONGO_USER_COLLECTION=users
# MONGO_NOTIFICATION_COLLECTION=notifications

# JWT (bắt buộc cho đăng nhập)
JWT_ACCESS_SECRET=your_jwt_access_secret_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# CORS & app URL
CORS_ORIGIN=http://localhost:3000
BASE_URL=http://localhost
# FRAME_ANCESTORS='self' http://localhost:3000

# PayOS (bắt buộc nếu dùng thanh toán PayOS)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
# PAYOS_RETURN_URL=http://localhost:3000/profile
# PAYOS_CANCEL_URL=http://localhost:3000/payment

# VIP / gói (tùy chọn)
VIP_PRICE_PAYOS=100000
VIP_PRICE_TRANSFER=95000
VIP_PACKAGE_NAME=VIP Pro
VIP_DURATION=Vinh vien

# AI (Gemini) – cần nếu dùng tính năng AI
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
# AI_FREE_LIMIT=1
